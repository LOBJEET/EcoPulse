rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userHabits/{docId} {
      allow read, write: if request.auth != null && docId.startsWith(request.auth.uid + "_");
    }

    match /userHabitLists/{docId} {
      allow read, write: if request.auth != null && docId == request.auth.uid;
    }

    match /actionLogs/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /userPublicStats/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && docId == request.auth.uid;
    }

    match /communityStats/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && docId == "global";
    }

    match /communityGroups/{groupId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    match /communityGroups/{groupId}/messages/{messageId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
